# === STRIPE (obrigatorio para checkout) ===
# Use chaves separadas por ambiente. NUNCA hardcode chaves live.
# Gere em: https://dashboard.stripe.com/apikeys
STRIPE_SECRET_KEY=sk_test_your-stripe-secret-key
STRIPE_PUBLISHABLE_KEY=pk_test_your-stripe-publishable-key
# Webhook secret generico (fallback)
STRIPE_WEBHOOK_SECRET=whsec_your-webhook-secret
# Webhooks separados por ambiente (recomendado)
STRIPE_WEBHOOK_SECRET_PRODUCTION=whsec_your-production-webhook-secret
STRIPE_WEBHOOK_SECRET_TEST=whsec_your-test-webhook-secret

# === ABACATEPAY (PIX) ===
# Use para pagamentos via PIX. Gere em: https://app.abacatepay.com/api-keys
ABACATEPAY_API_KEY=abacate_your-api-key
ABACATEPAY_WEBHOOK_SECRET=your-abacatepay-webhook-secret
# Modo sandbox (true = https://api.sandbox.abacatepay.com, false = https://api.abacatepay.com)
# Conta nova: usar sandbox ate homologar. Mudar para false em producao.
ABACATEPAY_SANDBOX_MODE=true

# === DEEPSEEK ===
DEEPSEEK_API_KEY=sk-your-deepseek-api-key-here

# Swarms Cloud (publicar agente como API)
SWARMS_CLOUD_API_KEY=your-swarms-cloud-api-key

# OpenStall (mercado agente-para-agente)
OPENSTALL_CREDITS=1000

# Google A2A Protocol
A2A_ENABLED=true
A2A_BASE_URL=https://engenheiro-producao-ai.onrender.com

# Microsoft Azure Marketplace (SaaS Fulfillment API v2)
AZURE_TENANT_ID=your-azure-tenant-id
AZURE_CLIENT_ID=your-azure-client-id
AZURE_CLIENT_SECRET=your-azure-client-secret

# Oracle Cloud Marketplace (OCI credentials)
OCI_CONFIG_FILE=~/.oci/config
OCI_PROFILE=DEFAULT
OCI_USE_INSTANCE_PRINCIPAL=false
OCI_USE_RESOURCE_PRINCIPAL=false

# AWS Marketplace (credenciais IAM com permissao AWS Marketplace)
AWS_ACCESS_KEY_ID=your-aws-access-key
AWS_SECRET_ACCESS_KEY=your-aws-secret-key
AWS_SUBSCRIBE_REDIRECT_URL=https://engenheiro-producao-ai.onrender.com/dashboard

# Salesforce AgentExchange (JWT Bearer Flow)
SALESFORCE_KEY_PATH=marketplace-integration/salesforce/salesforce.key
SALESFORCE_CLIENT_ID=your-salesforce-client-id
SALESFORCE_USERNAME=your-salesforce-username

# HashiCorp Vault
VAULT_TOKEN=your-vault-root-token
VAULT_ADDR=http://localhost:8200

# Banco de dados local (PostgreSQL no Render)
DATABASE_URL=postgresql://user:password@host:5432/hmas

# Kafka (Confluent Cloud ou Upstash)
KAFKA_BOOTSTRAP_SERVERS=localhost:9092

# Gemini (agentes sensiveis LGPD/NR-1)
GEMINI_API_KEY=your_gemini_api_key

# Claude API (raciocinio complexo — orchestrator, critic, evolution)
CLAUDE_API_KEY=your-claude-api-key

# Microsoft Dynamics 365
DYNAMICS_CLIENT_ID=your-dynamics-client-id
DYNAMICS_CLIENT_SECRET=your-dynamics-client-secret
DYNAMICS_TENANT_ID=your-dynamics-tenant-id
DYNAMICS_SALES_URL=https://your-org.crm.dynamics.com
DYNAMICS_FINANCE_URL=https://your-org.operations.dynamics.com

# Salesforce Agentforce
SALESFORCE_INSTANCE_URL=https://your-org.my.salesforce.com

# Oracle Fusion
ORACLE_FUSION_ERP_URL=https://your-org.fa.us.oraclecloud.com
ORACLE_FUSION_HCM_URL=https://your-org.hcm.us.oraclecloud.com
ORACLE_FUSION_SCM_URL=https://your-org.scm.us.oraclecloud.com

# SAP BTP
SAP_BTP_URL=https://your-btp-subdomain.authentication.us10.hana.ondemand.com

# Infraestrutura Docker
POSTGRES_PASSWORD=your-postgres-password
NEO4J_PASSWORD=your-neo4j-password
MINIO_USER=hmas_admin
MINIO_PASSWORD=your-minio-password
GRAFANA_PASSWORD=your-grafana-password
