# AION - Environment Variables
# Copy to .env and fill in your values

# LLM API Keys
DEEPSEEK_API_KEY=sk-your-deepseek-key
GEMINI_API_KEY=your-gemini-key
OPENROUTER_API_KEY=sk-or-v1-your-key
CLAUDE_API_KEY=sk-ant-your-claude-key

# Database
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_KEY=your-supabase-key
QDRANT_HOST=localhost
QDRANT_PORT=6333
QDRANT_COLLECTION=aion_embeddings
TIMESCALE_HOST=localhost
TIMESCALE_PORT=5432
TIMESCALE_DATABASE=aion_metrics
TIMESCALE_USER=postgres
TIMESCALE_PASSWORD=your-password

# Stripe
STRIPE_API_KEY=sk_test_your-stripe-key
STRIPE_WEBHOOK_SECRET=whsec_your-webhook-secret

# PIX
ABACATEPAY_API_KEY=your-abacatepay-key

# Azure / Microsoft
AZURE_TENANT_ID=your-tenant-id
AZURE_CLIENT_ID=your-client-id
AZURE_CLIENT_SECRET=your-client-secret

# GCP
GCP_PROJECT_ID=your-gcp-project

# Salesforce
SALESFORCE_INSTANCE_URL=https://your-instance.salesforce.com
SALESFORCE_CLIENT_ID=your-sf-client-id
SALESFORCE_CLIENT_SECRET=your-sf-client-secret

# AION
AION_ENVIRONMENT=development
AION_DEBUG=false
AION_LOG_LEVEL=INFO
