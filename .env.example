DEEPSEEK_API_KEY=sk-your-deepseek-api-key-here
STRIPE_SECRET_KEY=sk_test_your-stripe-secret-key
STRIPE_PUBLISHABLE_KEY=pk_test_your-stripe-publishable-key
STRIPE_WEBHOOK_SECRET=whsec_your-webhook-secret
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_API_KEY=your-supabase-api-key
APP_ENV=development
LOG_LEVEL=INFO

# Swarms Cloud (publicar agente como API)
SWARMS_CLOUD_API_KEY=your-swarms-cloud-api-key

# OpenStall (mercado agente-para-agente)
OPENSTALL_CREDITS=1000

# Google A2A Protocol
A2A_ENABLED=true
A2A_BASE_URL=https://engenheiro-producao-ai.onrender.com

# Microsoft Azure Marketplace (SaaS Fulfillment API v2)
AZURE_TENANT_ID=your-azure-tenant-id
AZURE_CLIENT_ID=your-azure-client-id
AZURE_CLIENT_SECRET=your-azure-client-secret

# Oracle Cloud Marketplace (OCI credentials)
OCI_CONFIG_FILE=~/.oci/config
OCI_PROFILE=DEFAULT
OCI_USE_INSTANCE_PRINCIPAL=false
OCI_USE_RESOURCE_PRINCIPAL=false

# AWS Marketplace (credenciais IAM com permissao AWS Marketplace)
AWS_ACCESS_KEY_ID=your-aws-access-key
AWS_SECRET_ACCESS_KEY=your-aws-secret-key
AWS_SUBSCRIBE_REDIRECT_URL=https://engenheiro-producao-ai.onrender.com/dashboard

# Salesforce AgentExchange (JWT Bearer Flow)
SALESFORCE_KEY_PATH=marketplace-integration/salesforce/salesforce.key
SALESFORCE_CLIENT_ID=your-salesforce-client-id
SALESFORCE_USERNAME=your-salesforce-username

# HashiCorp Vault
VAULT_TOKEN=your-vault-root-token
VAULT_ADDR=http://localhost:8200

# Infraestrutura Docker
POSTGRES_PASSWORD=your-postgres-password
NEO4J_PASSWORD=your-neo4j-password
MINIO_USER=hmas_admin
MINIO_PASSWORD=your-minio-password
GRAFANA_PASSWORD=your-grafana-password
